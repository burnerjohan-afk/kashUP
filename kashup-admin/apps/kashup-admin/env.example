# URL de l'API backend
# En développement local : http://localhost:4000
# En production : https://api.kashup.local (ou votre URL de production)
VITE_API_URL=http://localhost:4000

# Activer/désactiver les mocks MSW (Mock Service Worker)
# true = utiliser les mocks pour le développement offline
# false = utiliser l'API backend réelle
VITE_ENABLE_MSW=false

# Configuration pour la synchronisation avec l'application mobile
# URL de l'API mobile pour recevoir les webhooks de synchronisation
VITE_MOBILE_WEBHOOK_URL=https://mobile-api.kashup.local/api/webhooks/admin-sync
# Activer la synchronisation automatique lors des modifications
VITE_AUTO_SYNC_ENABLED=true

