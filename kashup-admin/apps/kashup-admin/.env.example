# URL de l'API KashUP (doit être la même que celle utilisée par l'app mobile pour voir les données ici dans l'app)
# En local : utiliser VITE_API_URL ci-dessous. En production (Vercel) : définir VITE_API_BASE_URL dans les variables d'environnement du projet.
# Sans VITE_API_BASE_URL en prod, les images et les appels API pointent vers localhost et ne s'affichent pas en ligne.
VITE_API_URL=http://localhost:4000
# Production (à définir sur Vercel pour le projet kashup-admin) — remplacer par l'URL réelle de ton API :
VITE_API_BASE_URL=https://VOTRE-API.vercel.app/api/v1

VITE_ENABLE_MSW=false

# Optionnel : webhooks de synchronisation
# VITE_MOBILE_WEBHOOK_URL=https://mobile-api.kashup.local/api/webhooks/admin-sync
# VITE_AUTO_SYNC_ENABLED=true
