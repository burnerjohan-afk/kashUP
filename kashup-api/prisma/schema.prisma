generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String                  @id @default(cuid())
  email             String                  @unique
  hashedPassword    String
  appleId           String?                 @unique  // Sign in with Apple
  googleId          String?                 @unique  // Sign in with Google
  firstName         String
  lastName          String
  phone             String?
  role              String                  @default("user")
  territory         String?                 @default("Martinique")
  gender            String?                // M | F | other — collecté à l'inscription
  ageRange          String?                // ex. 18-25, 26-35, 36-50, 50+ — collecté à l'inscription
  partnerId         String?                @unique  // Si role=partner, lien vers le partenaire
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  partner           Partner?               @relation(fields: [partnerId], references: [id])
  bankAccessLogs    BankAccessLog[]
  bankConsents      BankConsent[]
  challengeProgress ChallengeProgress[]
  donations         DonationImpact[]
  favorites         FavoritePartner[]
  giftCardPurchases GiftCardPurchase[]      @relation("GiftCardPurchaser")
  receivedPredefinedGifts PredefinedGiftSend[] @relation("PredefinedGiftSendBeneficiary")
  sentPredefinedGifts     PredefinedGiftSend[] @relation("PredefinedGiftSendSender")
  lotteryEntries    LotteryEntry[]
  lotteryTickets    LotteryTicket[]
  lotteryWins       LotteryWinner[]
  notifications     Notification[]
  pointsHistory     Points[]
  powensConnections PowensConnection[]
  powensLinkTokens  PowensLinkToken[]
  referral          Referral?
  rewardHistory     RewardHistory[]
  transactions      Transaction[]
  badges            UserBadge[]
  bankConnections   UserBankConnection[]
  boosts            UserBoost[]
  budgetSnapshots   UserBudgetSnapshot[]
  consent           UserConsent?
  paymentMethods    UserPaymentMethod[]
  securityEvents    UserSecurityEvent[]
  wallet            Wallet?
  walletSnapshots   WalletMonthlySnapshot[]
  coffreFortMovements   CoffreFortMovement[]
  coffreFortWithdrawals CoffreFortWithdrawal[]
  coffreFortPoints      CoffreFortPointsEntry[]
  jackpotEntries        JackpotEntry[]
  jackpotContributions  JackpotContribution[]
  jackpotWins           JackpotWinner[]
}

model PartnerCategory {
  id            String         @id @default(cuid())
  name          String         @unique
  boosts        Boost[]
  cashbackRates CashbackRate[]
  partners      Partner[]
}

model Partner {
  id                String            @id @default(cuid())
  name              String
  slug              String            @unique
  logoUrl           String?
  shortDescription  String?
  description       String?
  siret             String?
  phone             String?
  openingHours      String?   // Horaires d'ouverture/fermeture (ex: "Lun-Ven 9h-18h" ou texte libre)
  openingDays       String?  // Jours d'ouverture (JSON array: ["monday","tuesday",...])
  address           String?   // Adresse complète du partenaire (fallback si pas de territoryDetails)
  websiteUrl        String?
  facebookUrl       String?
  instagramUrl      String?
  territoryDetails  String?  // JSON: { "Martinique": { address, websiteUrl, facebookUrl, instagramUrl }, "Guadeloupe": {...}, "Guyane": {...} }
  tauxCashbackBase  Float
  discoveryCashbackRate Float? // Taux de cashback de bienvenue
  permanentCashbackRate Float? // Taux de cashback permanent
  discoveryCashbackKashupShare Float? // Part du taux de cashback de bienvenue pour KashUP (en %)
  discoveryCashbackUserShare Float? // Part du taux de cashback de bienvenue pour l'utilisateur (en %)
  permanentCashbackKashupShare Float? // Part du taux de cashback permanent pour KashUP (en %)
  permanentCashbackUserShare Float? // Part du taux de cashback permanent pour l'utilisateur (en %)
  pointsPerTransaction Int? // Nombre de points par transaction
  territories       String?
  latitude          Float?
  longitude         Float?
  boostable         Boolean           @default(true)
  giftCardEnabled   Boolean          @default(false) // Activer les cartes cadeaux / bons d'achat
  categoryId        String
  status            String?           @default("active") // Statut du partenaire (active, inactive, pending, etc.)
  additionalInfo    String? // Informations complémentaires (JSON ou texte)
  affiliations      String? // Affiliations (JSON array)
  menuImages        String?
  photos            String?
  marketingPrograms String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  boosts            Boost[]
  boxUpPartners     BoxUpPartner[]
  cashbackRates     CashbackRate[]
  favorites         FavoritePartner[]
  giftBoxItems         GiftBoxItem[]
  giftCards            GiftCard[]
  carteUpPredefinies   CarteUpPredefinie[]
  category             PartnerCategory   @relation(fields: [categoryId], references: [id])
  documents         PartnerDocument[]
  offers            PartnerOffer[]
  transactions      Transaction[]
  users             User[]                 // Comptes espace partenaire (role=partner)
  challenges        Challenge[]
  lotteries         Lottery[]

  @@index([categoryId])
}

model PartnerOffer {
  id           String    @id @default(cuid())
  partnerId    String?
  title        String
  subtitle     String?
  description  String?
  imageUrl     String?
  priority     Int       @default(1)
  rewardType   String?
  startsAt     DateTime
  endsAt       DateTime
  active       Boolean   @default(true)
  price        Float?
  cashbackRate Float?
  stock        Int?
  stockUsed    Int       @default(0)
  status       String    @default("scheduled")
  conditions   String?
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  partner      Partner?  @relation(fields: [partnerId], references: [id])

  @@index([updatedAt])
}

// Bannières publicitaires page d'accueil (images ou vidéos, défilement horizontal)
model HomeBanner {
  id        String   @id @default(cuid())
  title     String?  // Libellé optionnel (ex: "Offre du moment")
  mediaType String   @default("image") // "image" | "video"
  imageUrl  String?  // URL image (pour image ou miniature vidéo)
  videoUrl  String?  // URL vidéo (optionnel)
  linkUrl   String?  // Lien au clic (optionnel)
  position  Int      @default(0) // Ordre d'affichage
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CashbackRate {
  id         String           @id @default(cuid())
  partnerId  String?
  categoryId String?
  territory  String
  rate       Float
  createdAt  DateTime         @default(now())
  category   PartnerCategory? @relation(fields: [categoryId], references: [id])
  partner    Partner?         @relation(fields: [partnerId], references: [id])
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  soldeCashback   Float    @default(0)
  soldePoints     Int      @default(0)
  soldeCoffreFort Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id])
}

// Règle coffre-fort : blocage 2 mois, X points par € par mois (configurable en back office)
model CoffreFortConfig {
  id                    String   @id @default(cuid())
  lockPeriodMonths      Int      @default(2)
  pointsPerEuroPerMonth Float    @default(10)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

// Chaque versement en coffre-fort : montant, date de déblocage
model CoffreFortMovement {
  id              String   @id @default(cuid())
  userId          String
  amount          Float
  amountWithdrawn Float   @default(0)
  lockedAt        DateTime @default(now())
  unlockAt        DateTime
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([unlockAt])
}

model CoffreFortWithdrawal {
  id          String   @id @default(cuid())
  userId      String
  amount      Float
  withdrawnAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CoffreFortPointsEntry {
  id        String   @id @default(cuid())
  userId    String
  points    Int
  earnedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WalletMonthlySnapshot {
  id              String   @id @default(cuid())
  userId          String
  month           String
  objectiveAmount Float    @default(0)
  injectedAmount  Float    @default(0)
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model Points {
  id        String   @id @default(cuid())
  userId    String
  delta     Int
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Transaction {
  id              String   @id @default(cuid())
  userId          String
  partnerId       String
  amount          Float
  cashbackEarned  Float
  pointsEarned    Int
  transactionDate DateTime @default(now())
  source          String   @default("carte")
  status          String   @default("confirmed")
  metadata        String?
  partner         Partner  @relation(fields: [partnerId], references: [id])
  user            User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([partnerId])
}

model Boost {
  id           String           @id @default(cuid())
  name         String           @unique
  description  String
  multiplier   Float            @default(1.0)
  target       String           @default("all")
  categoryId   String?
  partnerId    String?
  costInPoints Int
  startsAt     DateTime
  endsAt       DateTime
  active       Boolean          @default(true)
  updatedAt    DateTime         @updatedAt
  deletedAt    DateTime?
  partner      Partner?         @relation(fields: [partnerId], references: [id])
  category     PartnerCategory? @relation(fields: [categoryId], references: [id])
  users        UserBoost[]

  @@index([updatedAt])
}

model UserBoost {
  id          String   @id @default(cuid())
  userId      String
  boostId     String
  activatedAt DateTime @default(now())
  expiresAt   DateTime
  boost       Boost    @relation(fields: [boostId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, boostId])
}

model Badge {
  id              String      @id @default(cuid())
  name            String      @unique
  description     String
  level           Int
  unlockCondition String
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  users           UserBadge[]

  @@index([updatedAt])
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  obtainedAt DateTime @default(now())
  badge      Badge    @relation(fields: [badgeId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
}

model GiftCard {
  id          String             @id @default(cuid())
  type        String             @default("bon_achat")
  name        String
  description String
  value       Float
  partnerId   String?
  isGiftable  Boolean            @default(true)
  updatedAt   DateTime           @updatedAt
  deletedAt   DateTime?
  partner     Partner?           @relation(fields: [partnerId], references: [id])
  purchases   GiftCardPurchase[]

  @@index([updatedAt])
}

model GiftCardPurchase {
  id               String   @id @default(cuid())
  giftCardId       String
  purchaserId      String
  beneficiaryEmail String
  message          String?
  amount           Float
  code             String   @unique
  expiresAt        DateTime
  status           String   @default("actif")
  createdAt        DateTime @default(now())
  giftCard         GiftCard @relation(fields: [giftCardId], references: [id])
  purchaser        User     @relation("GiftCardPurchaser", fields: [purchaserId], references: [id])
}

model GiftBox {
  id           String        @id @default(cuid())
  name         String
  description  String
  imageUrl     String?
  cashbackInfo String?
  value        Float         @default(0)
  cashbackRate Float?        // Taux de cashback (%) à l'achat de la box
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  items        GiftBoxItem[]
}

model GiftBoxItem {
  id          String   @id @default(cuid())
  giftBoxId   String
  partnerId   String?
  title       String
  description String?
  partner     Partner? @relation(fields: [partnerId], references: [id])
  giftBox     GiftBox  @relation(fields: [giftBoxId], references: [id])
}

model GiftCardAmount {
  id        String   @id @default(cuid())
  amount    Float    // montant en euros (ex: 5, 10, 20, 50, 100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Carte Sélection UP : config (partenaires éligibles, montant libre) ; l'utilisateur crée sa carte
model CarteUpLibreConfig {
  id                   String   @id @default(cuid())
  nom                  String
  description          String
  imageUrl             String?
  montantsDisponibles  String   @default("[]") // JSON array of numbers, vide = montant libre
  partenairesEligibles String   // JSON array of partner IDs
  conditions           String?
  commentCaMarche      String?
  cashbackRate         Float?   // Taux de cashback (%) à l'achat
  status               String   @default("active") // active | inactive
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// Carte UP : créée par l'admin (partenaire, montant, image, validité) ; l'utilisateur ajoute texte + macaron
model CarteUpPredefinie {
  id                 String    @id @default(cuid())
  nom                String
  partenaireId       String
  offre              String?
  montant            Float
  imageUrl           String?
  description        String
  dureeValiditeJours Int?
  conditions         String?
  commentCaMarche    String?
  cashbackRate       Float?    // Taux de cashback (%) à l'achat
  status             String    @default("active")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  partner            Partner   @relation(fields: [partenaireId], references: [id])
}

model PredefinedGift {
  id        String    @id @default(cuid())
  title     String
  subtitle  String?
  imageUrl  String?
  amount    Float
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([updatedAt])
}

// Cadeau prédefini ou Carte Sélection UP envoyé (notification in-app ou par email)
model PredefinedGiftSend {
  id                 String   @id @default(cuid())
  offerId            String   @default("") // id PredefinedGift, CarteUpPredefinie, ou partnerId pour selection_up
  offerType          String   // 'predefined' | 'carte_up' | 'box_up' | 'selection_up'
  senderId           String
  beneficiaryUserId  String?  // null si envoi par email à un non-inscrit
  beneficiaryEmail   String
  message            String?
  amount             Float
  offerTitle         String
  createdAt          DateTime @default(now())
  sender             User     @relation("PredefinedGiftSendSender", fields: [senderId], references: [id])
  beneficiary        User?    @relation("PredefinedGiftSendBeneficiary", fields: [beneficiaryUserId], references: [id])

  @@index([beneficiaryUserId])
}

model FavoritePartner {
  id        String   @id @default(cuid())
  userId    String
  partnerId String
  createdAt DateTime @default(now())
  partner   Partner  @relation(fields: [partnerId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, partnerId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  title     String
  body      String
  category  String    @default("system")
  metadata  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([userId, category])
}

model Referral {
  id           String           @id @default(cuid())
  userId       String           @unique
  code         String           @unique
  rewardPoints Int              @default(0)
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id])
  invites      ReferralInvite[]
}

model ReferralInvite {
  id            String    @id @default(cuid())
  referralId    String
  inviteeEmail  String
  status        String    @default("pending")
  completedAt   DateTime?
  rewardGranted Boolean   @default(false)
  createdAt     DateTime  @default(now())
  referral      Referral  @relation(fields: [referralId], references: [id])
}

model DonationCategory {
  id           String                @id @default(cuid())
  name         String                @unique
  description  String?
  updatedAt    DateTime              @updatedAt
  deletedAt    DateTime?
  associations DonationAssociation[]

  @@index([updatedAt])
}

model DonationAssociation {
  id          String                 @id @default(cuid())
  name        String
  description String?
  tonImpact   String?                // Texte "Ton impact" pour le back office
  logoUrl     String?
  websiteUrl  String?
  department  String?
  categoryId  String
  status      String                 @default("active") // draft | active
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  deletedAt   DateTime?
  category    DonationCategory       @relation(fields: [categoryId], references: [id])
  donations   DonationImpact[]
  spotlights  SpotlightAssociation[]

  @@index([updatedAt])
}

model DonationImpact {
  id            String              @id @default(cuid())
  associationId String
  userId        String?
  amount        Float
  createdAt     DateTime            @default(now())
  user          User?               @relation(fields: [userId], references: [id])
  association   DonationAssociation @relation(fields: [associationId], references: [id])
}

model SpotlightAssociation {
  id            String              @id @default(cuid())
  associationId String
  spotlightType String              @default("home")
  startsAt      DateTime
  endsAt        DateTime
  active        Boolean             @default(true)
  updatedAt     DateTime            @updatedAt
  deletedAt     DateTime?
  association   DonationAssociation @relation(fields: [associationId], references: [id])

  @@index([updatedAt])
}

model RewardHistory {
  id        String   @id @default(cuid())
  userId    String
  category  String
  title     String
  details   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, category])
}

model Lottery {
  id                    String          @id @default(cuid())
  title                 String
  description           String?
  shortDescription      String?
  imageUrl              String?
  prizeType             String?         // carte_cadeau | bon_achat | cashback | points_bonus | box | avantage_partenaire | badge | boost
  prizeTitle            String?
  prizeDescription      String?
  prizeValue            Float?
  prizeCurrency         String?         @default("EUR")
  rewardId              String?
  partnerId             String?
  pointsPerTicket       Int             @default(100)
  ticketCost            Int?            // deprecated, use pointsPerTicket
  isTicketStockLimited  Boolean         @default(false)
  totalTicketsAvailable Int?            // null = illimité
  totalTicketsSold      Int             @default(0)
  maxTicketsPerUser     Int?            // null = illimité
  startDate             DateTime?
  endDate               DateTime?
  startAt               DateTime        // legacy
  endAt                 DateTime
  drawDate              DateTime?
  status                String          @default("upcoming") // upcoming | active | closed
  winnerUserId          String?
  showOnHome            Boolean         @default(false)
  showOnRewards         Boolean         @default(true)
  active                Boolean         @default(true)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  deletedAt             DateTime?
  entries               LotteryEntry[]
  tickets               LotteryTicket[]
  winners               LotteryWinner[]
  partner               Partner?        @relation(fields: [partnerId], references: [id])

  @@index([updatedAt])
  @@index([status])
  @@index([showOnHome])
  @@index([showOnRewards])
}

model LotteryEntry {
  id          String   @id @default(cuid())
  lotteryId   String
  userId      String
  tickets     Int      @default(1)   // legacy alias for ticketCount
  ticketCount Int      @default(1)
  pointsSpent Int      @default(0)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
  lottery     Lottery  @relation(fields: [lotteryId], references: [id])
  ticketRows  LotteryTicket[]

  @@unique([lotteryId, userId])
  @@index([lotteryId])
  @@index([userId])
}

model LotteryTicket {
  id         String   @id @default(cuid())
  lotteryId  String
  userId     String
  entryId    String
  ticketNumber Int
  status     String   @default("valid") // valid | used | void
  createdAt  DateTime @default(now())
  lottery    Lottery  @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
  entry      LotteryEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  @@unique([lotteryId, ticketNumber])
  @@index([lotteryId])
  @@index([userId])
  @@index([entryId])
}

model LotteryWinner {
  id           String    @id @default(cuid())
  lotteryId    String
  userId       String
  entryId      String
  ticketId     String?
  drawDate     DateTime  @default(now())
  rewardStatus String    @default("pending") // pending | delivered
  deliveredAt  DateTime?
  createdAt    DateTime  @default(now())
  lottery      Lottery   @relation(fields: [lotteryId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id])

  @@index([lotteryId])
  @@index([userId])
}

// ========== Jackpot communautaire ==========
// Config singleton (règles configurables en back-office)
model CommunityJackpotConfig {
  id                                 String   @id @default(cuid())
  cashbackContributionPercent        Float    @default(0)   // % du cashback partenaires alimentant le jackpot
  lotteryPointsContribution          Int      @default(0)   // points jackpot par ticket loterie
  challengePointsContribution        Int      @default(0)   // points jackpot par challenge complété
  globalPartnerPurchaseAmountThreshold Float  @default(0)  // montant total achats pour déclencher tirage
  globalActionsThreshold            Int      @default(0)   // nombre total d'actions pour déclencher tirage
  minActionsPerUser                  Int      @default(0)   // min actions pour être éligible au gain
  minPartnerPurchasesPerUser         Int?                   // min achats partenaires pour être éligible (optionnel)
  freeParticipationTickets           Int      @default(1)   // tickets donnés par participation gratuite
  partnerPurchaseTickets             Int      @default(0)   // tickets par achat partenaire
  lotteryTicketTickets               Int      @default(0)   // tickets par participation loterie
  challengeCompletionTickets         Int      @default(0)   // tickets par challenge complété
  maxDrawDate                        DateTime?             // date max tirage si seuils non atteints (appliquée au jackpot actif)
  createdAt                          DateTime @default(now())
  updatedAt                          DateTime @updatedAt
}

model CommunityJackpot {
  id                         String    @id @default(cuid())
  title                      String    @default("Jackpot KashUP")
  description                String?
  currentAmount              Float     @default(0)
  currency                   String    @default("EUR")
  startDate                  DateTime  @default(now())
  maxDrawDate                DateTime?
  status                     String    @default("active")   // active | drawn | closed
  totalParticipants          Int       @default(0)
  totalActions               Int       @default(0)
  totalPartnerPurchasesAmount Float    @default(0)
  lastWinnerUserId           String?
  lastWinningAmount          Float?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt
  contributions              JackpotContribution[]
  entries                    JackpotEntry[]
  winners                    JackpotWinner[]

  @@index([status])
  @@index([maxDrawDate])
}

model JackpotContribution {
  id                  String    @id @default(cuid())
  jackpotId           String
  userId              String?   // null pour sponsor (contribution directe)
  sourceType          String    // partner_cashback | lottery_ticket | challenge_completion | free_participation | sponsor
  sourceReferenceId   String?   // transactionId, lotteryEntryId, challengeProgressId, partnerId (sponsor)
  contributionAmount  Float     @default(0)  // montant en € ajouté au jackpot
  contributionPoints  Int       @default(0)  // points jackpot (pour suivi)
  createdAt           DateTime  @default(now())
  jackpot             CommunityJackpot @relation(fields: [jackpotId], references: [id], onDelete: Cascade)
  user                User?    @relation(fields: [userId], references: [id])

  @@index([jackpotId])
  @@index([userId])
  @@index([sourceType])
}

model JackpotEntry {
  id                     String    @id @default(cuid())
  jackpotId              String
  userId                 String
  tickets                Int        @default(0)
  actionsCount           Int        @default(0)
  partnerPurchasesCount  Int        @default(0)
  isEligible             Boolean    @default(false)
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt
  jackpot                CommunityJackpot @relation(fields: [jackpotId], references: [id], onDelete: Cascade)
  user                   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([jackpotId, userId])
  @@index([jackpotId])
  @@index([userId])
}

model JackpotWinner {
  id            String    @id @default(cuid())
  jackpotId     String
  userId        String
  winningAmount Float
  drawDate      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  jackpot       CommunityJackpot @relation(fields: [jackpotId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])

  @@index([jackpotId])
  @@index([userId])
}

// Récompense associée à un challenge (cashback, points, gift_card, voucher, badge, boost)
model ChallengeReward {
  id              String    @id @default(cuid())
  rewardType      String    // cashback | points | gift_card | voucher | badge | boost
  rewardValue     Float     @default(0)   // montant ou quantité
  rewardCurrency String?   @default("EUR")
  expirationDays Int?      // validité en jours après attribution
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  challenges      Challenge[]
}

model Challenge {
  id           String              @id @default(cuid())
  title        String
  description  String?
  category     String?             // consentements | parrainages | cagnotte | achats | connexion | ma_fid — pour menu Badges & points façon Naomi
  type         String              @default("challenge_purchase") // challenge_purchase | challenge_spend | challenge_discovery | challenge_loyalty | challenge_invite | challenge_geo | challenge_event
  goalType     String              // alias sémantique (ex: "partners" | "amount" | "visits")
  goalValue    Int                 // ex: 3 partenaires, 50€, 5 achats
  rewardPoints Int                 @default(0) // rétrocompat
  rewardId     String?
  difficulty   String?             @default("medium") // easy | medium | hard
  startAt      DateTime
  endAt        DateTime
  status       String              @default("active") // upcoming | active | ended
  partnerId    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  deletedAt    DateTime?
  progressions ChallengeProgress[]
  reward       ChallengeReward?    @relation(fields: [rewardId], references: [id])
  partner      Partner?            @relation(fields: [partnerId], references: [id])

  @@index([updatedAt])
  @@index([status])
  @@index([type])
  @@index([category])
}

model ChallengeProgress {
  id          String    @id @default(cuid())
  challengeId String
  userId      String
  progress    Int       @default(0)
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id])
  challenge   Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([userId])
}

model UserBankConnection {
  id           String    @id @default(cuid())
  userId       String
  provider     String
  status       String    @default("active")
  lastSyncAt   DateTime?
  accountsJson String?
  user         User      @relation(fields: [userId], references: [id])
}

model UserBudgetSnapshot {
  id        String   @id @default(cuid())
  userId    String
  month     String
  income    Float    @default(0)
  expenses  Float    @default(0)
  savings   Float    @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, month])
}

model UserPaymentMethod {
  id        String   @id @default(cuid())
  userId    String
  provider  String
  type      String
  last4     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model UserSecurityEvent {
  id          String    @id @default(cuid())
  userId      String
  title       String
  description String?
  createdAt   DateTime  @default(now())
  resolvedAt  DateTime?
  user        User      @relation(fields: [userId], references: [id])
}

model PowensLinkToken {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model PowensConnection {
  id                 String          @id @default(cuid())
  userId             String
  powensUserId       String?
  powensConnectionId String?
  accessToken        String
  status             String          @default("active")
  lastSyncAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  accessLogs         BankAccessLog[]
  bankAccounts       BankAccount[]
  bankConsents       BankConsent[]
  user               User            @relation(fields: [userId], references: [id])

  @@unique([userId, powensConnectionId])
  @@index([userId])
}

model BankAccount {
  id               String            @id @default(cuid())
  connectionId     String
  powensAccountId  String?
  label            String
  iban             String?
  balance          Float             @default(0)
  currency         String            @default("EUR")
  type             String?
  raw              String?
  lastSyncAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  connection       PowensConnection  @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  bankTransactions BankTransaction[]

  @@unique([connectionId, powensAccountId])
  @@index([connectionId])
}

model BankTransaction {
  id                  String      @id @default(cuid())
  accountId           String
  powensTransactionId String?
  date                DateTime
  amount              Float
  label               String
  category            String?
  raw                 String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  account             BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, powensTransactionId])
  @@index([accountId])
  @@index([date])
}

model AdminReportLog {
  id        String   @id @default(cuid())
  type      String
  payload   String?
  createdAt DateTime @default(now())
}

model GiftCardConfig {
  id                          String   @id @default(cuid())
  giftCardDescription         String?
  giftCardImageUrl            String?
  giftCardVirtualCardImageUrl String?
  giftCardHowItWorks          String?
  giftCardConditions          String?
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model BoxUpConfig {
  id              String         @id @default(cuid())
  boxUpName       String
  boxUpImageUrl   String?
  boxUpHowItWorks String?
  boxUpConditions String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  partners        BoxUpPartner[]
}

model BoxUpPartner {
  id            String      @id @default(cuid())
  boxUpConfigId String
  partnerId     String
  partner       Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  boxUpConfig   BoxUpConfig @relation(fields: [boxUpConfigId], references: [id], onDelete: Cascade)

  @@unique([boxUpConfigId, partnerId])
}

model PartnerDocument {
  id        String   @id @default(cuid())
  partnerId String
  name      String
  type      String
  url       String
  size      String?
  createdAt DateTime @default(now())
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  @@index([partnerId])
}

model UserConsent {
  id                   String    @id @default(cuid())
  userId               String    @unique
  privacyPolicy        Boolean   @default(false)
  privacyPolicyAt      DateTime?
  privacyPolicyVersion String?
  marketing            Boolean   @default(false)
  marketingAt          DateTime?
  analytics            Boolean   @default(false)
  analyticsAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BankConsent {
  id               String           @id @default(cuid())
  userId           String
  connectionId     String
  consentGiven     Boolean          @default(false)
  consentGivenAt   DateTime?
  consentRevoked   Boolean          @default(false)
  consentRevokedAt DateTime?
  scope            String
  expiresAt        DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  connection       PowensConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, connectionId])
  @@index([userId])
  @@index([connectionId])
}

model BankAccessLog {
  id           String            @id @default(cuid())
  userId       String
  connectionId String?
  action       String
  ipAddress    String?
  userAgent    String?
  success      Boolean
  errorMessage String?
  metadata     String?
  createdAt    DateTime          @default(now())
  connection   PowensConnection? @relation(fields: [connectionId], references: [id])
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([connectionId])
  @@index([createdAt])
  @@index([action])
}
