NODE_ENV=development
PORT=4000
DATABASE_URL="file:./dev.db"
JWT_SECRET="changeme-en-prod"
REFRESH_TOKEN_SECRET="changeme-too"

# Chiffrement des données sensibles (RGPD Art. 32)
# Générer avec: openssl rand -base64 32
# DOIT faire au moins 32 caractères
ENCRYPTION_KEY="votre_clef_chiffrement_32_caracteres_minimum"

# CORS : back office (vite) + mobile + wildcard pour dev
CORS_ORIGIN="http://localhost:5173,http://localhost:3000,*"

# Powens — https://docs.powens.com/documentation/
# Requis pour webview (connexion banque) : Configuration → Client ID, Client secret, Redirect URI
POWENS_DOMAIN="kashup-sandbox"
POWENS_API_URL="https://kashup-sandbox.biapi.pro/2.0/"
POWENS_CLIENT_ID="votre_client_id"
POWENS_CLIENT_SECRET="votre_client_secret"
POWENS_REDIRECT_URI="https://kashupv0.vercel.app/powens/callback"
# Optionnel : manage tokens (console → domaine / API Keys) pour list connections, budget, etc.
POWENS_CONFIG_KEY="votre_clef_config"
POWENS_MONITORING_KEY="votre_clef_surveillance"
POWENS_USERS_KEY="votre_clef_utilisateurs"
POWENS_ENCRYPTION_PUBLIC_KEY="votre_clef_RSA_base64"
POWENS_WEBHOOK_SECRET="votre_webhook_secret"
DRIMIFY_API_URL="https://api.drimify.com/v1"
DRIMIFY_API_KEY="cP6m_SvpdCy1vCTkcyp5LFFot16AMSyuwoHA73dXoVE"

# Webhooks - Synchronisation avec l'application mobile
# À adapter si vous utilisez ngrok ou un device physique
MOBILE_WEBHOOK_URL="http://localhost:3000/api/webhooks"

