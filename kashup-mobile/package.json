{
  "name": "kashup-mobile",
  "main": "expo/AppEntry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start --offline",
    "start:lan": "set EXPO_DEVTOOLS_LISTEN_ADDRESS=0.0.0.0 && expo start --lan --host lan",
    "start:offline": "expo start --offline",
    "start:tunnel": "expo start --tunnel",
    "start:clear": "expo start --clear --offline",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:preview:android": "eas build --platform android --profile preview",
    "build:preview:ios": "eas build --platform ios --profile preview",
    "build:preview:all": "eas build --platform all --profile preview",
    "build:production:android": "eas build --platform android --profile production",
    "build:production:ios": "eas build --platform ios --profile production",
    "build:production:all": "eas build --platform all --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.8.7",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.8.1",
    "@tanstack/query-async-storage-persister": "^5.90.14",
    "@tanstack/react-query": "^5.90.12",
    "@tanstack/react-query-persist-client": "^5.90.14",
    "axios": "^1.13.2",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-barcode-scanner": "^13.0.1",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "^17.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-qrcode-svg": "^6.3.20",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "@types/uuid": "^10.0.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "expo-image-loader": "6.0.0"
  },
  "expo": {
    "install": {
      "exclude": [
        "@react-navigation/bottom-tabs",
        "@react-navigation/native-stack",
        "@react-navigation/native"
      ]
    }
  },
  "private": true
}
